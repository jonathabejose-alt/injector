- name: SacredWare
  uses: SacredWare/actions-status-discord@v1
  if: always()
  with:
    webhook: ${{ secrets.DISCORD_WEBHOOK }}
    nodetail: true
    title: "New Update of SacredWare"
    description: |
      - Added installer

      Version `${{ github.ref_name }}`
      Click [here](https://github.com/jonathabejose-alt/SacredWare-Installer/releases/latest/download/SacredWare_Installer.exe) to download!
    color: 0xff91a4
